# ══════════════════════════════════════════════════════════════════════════
# Photography Portfolio — Environment Variables
# ══════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in all values.
# Never commit .env.local to git.

# ── Supabase ───────────────────────────────────────────────────────────────
# Found at: supabase.com → your project → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Cloudinary ─────────────────────────────────────────────────────────────
# Found at: cloudinary.com → Dashboard

NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Photographer info — shown on the public site ───────────────────────────
# Change these to personalise the site without touching code.

NEXT_PUBLIC_PHOTOGRAPHER_NAME=Alex Chen
NEXT_PUBLIC_PHOTOGRAPHER_EMAIL=hello@alexchen.com
NEXT_PUBLIC_PHOTOGRAPHER_INSTAGRAM=@alexchen

# Optional: after uploading your headshot to Cloudinary, paste the URL here
# NEXT_PUBLIC_PHOTOGRAPHER_PORTRAIT_URL=https://res.cloudinary.com/your-cloud/image/upload/q_auto,f_auto/your-portrait-id
